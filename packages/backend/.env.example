# ─── Database (PostgreSQL) ─────────────────────────────────────────────────────
# Local Postgres or Docker:
#   docker run --name bharat-pg -e POSTGRES_PASSWORD=postgres -p 5432:5432 -d postgres:16
# Production: a managed Postgres URL (e.g. Neon, Supabase, RDS) — never commit the real value.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/bharat_benefits_ai"

# ─── Authentication & Security ────────────────────────────────────────────────
# JWT signing secret. Must be at least 32 bytes of cryptographically random data.
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
# MUST match the frontend's NEXTAUTH_SECRET so the two services produce
# mutually verifiable tokens.
JWT_SECRET="REPLACE_ME_WITH_A_RANDOM_32_BYTE_SECRET"

# AES-256 key for encrypting user profile data at rest (64-char hex, i.e. 32 bytes).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PROFILE_ENCRYPTION_KEY="REPLACE_ME_WITH_A_64_CHAR_HEX_STRING"

# ─── Redis ────────────────────────────────────────────────────────────────────
#   docker run --name bharat-redis -p 6379:6379 -d redis:7-alpine
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_PASSWORD=""
REDIS_DB=0
REDIS_KEY_PREFIX="bharat:"

# ─── Elasticsearch (OPTIONAL) ─────────────────────────────────────────────────
# Keyword search is served by Postgres FTS (tsvector + GIN index on the
# `schemes.search_doc` generated column — see migration
# 20260618000000_scheme_fts_tsvector). Leave these UNSET to disable
# Elasticsearch entirely; /readyz will skip the ES check and the crawler
# scheme-indexer will skip ES writes.
#
# Only set ELASTICSEARCH_NODE if you specifically want to run Elasticsearch
# alongside Postgres FTS (e.g. for richer multi-field BM25, the historical
# code path is preserved and re-enables itself when these vars are set).
# ELASTICSEARCH_NODE=""
# ELASTICSEARCH_API_KEY=""
# ELASTICSEARCH_USERNAME=""
# ELASTICSEARCH_PASSWORD=""

# ─── Vector Database (Pinecone) ───────────────────────────────────────────────
# Sign up at https://www.pinecone.io/
# IMPORTANT: index dimension MUST match the embedding model being used:
#   - Gemini text-embedding-004     → 768
#   - OpenAI text-embedding-3-small → 1536
PINECONE_API_KEY=""
PINECONE_INDEX_NAME="bharat-benefits-schemes"
PINECONE_NAMESPACE=""

# ─── Google Gemini AI ──────────────────────────────────────────────────────────
# Sign up at https://aistudio.google.com/
GEMINI_API_KEY=""
GEMINI_CHAT_MODEL="gemini-2.0-flash"
GEMINI_EMBEDDING_MODEL="text-embedding-004"

# ─── OpenAI (optional, fallback) ─────────────────────────────────────────────
OPENAI_API_KEY=""

# ─── Azure Cognitive Services (Voice) ─────────────────────────────────────────
AZURE_SPEECH_KEY=""
AZURE_SPEECH_REGION=""

# ─── Crawler ──────────────────────────────────────────────────────────────────
# Comma-separated list of official government source URLs. Empty = built-in defaults.
CRAWLER_SOURCE_URLS=""
# Opt-in: when "true", the daily worker also runs the discovery layer over each
# seed URL. Discovery extracts in-portal links, classifies them as
# scheme / listing / ministry / ignore, and feeds confirmed scheme URLs into
# the main crawler pipeline. Honours robots.txt and per-host throttling
# (1.5s between requests). Default off because it dramatically expands the
# per-run footprint — verify your seeds + run a manual crawl first.
CRAWLER_LINK_DISCOVERY="false"
# Opt-in: when "true", index.ts wires the daily-crawl scheduler so the crawler
# fires every 24h. Default off; flip after curating CRAWLER_SOURCE_URLS and
# verifying admin review tooling.
ENABLE_DAILY_CRAWL="false"

# ─── Email (Resend) ───────────────────────────────────────────────────────────
# Required for deadline notifications, lockout alerts, account confirmations.
# Sign up at https://resend.com — verify your sending domain before launch.
RESEND_API_KEY=""
# Must use a verified sender on your Resend account. Format:
#   "Display Name <noreply@yourdomain.in>"
RESEND_FROM=""
# Optional Reply-To header on all sent mail.
RESEND_REPLY_TO=""

# ─── Shared with frontend (NextAuth session signing) ─────────────────────────
# Must match the value set in packages/frontend/.env.local for the
# NextAuth → backend JWT exchange to validate.
NEXTAUTH_SECRET="REPLACE_ME_WITH_A_RANDOM_SECRET"

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=4000
HOST="0.0.0.0"
NODE_ENV="development"
FRONTEND_URL="http://localhost:3000"

# ─── Operational toggles ──────────────────────────────────────────────────────
# Set true on all-but-one replica when scaling horizontally so only one host
# owns the cron jobs (Req 1.4, 14.3 — daily verification + deadline scan).
DISABLE_SCHEDULER="false"
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW="1 minute"

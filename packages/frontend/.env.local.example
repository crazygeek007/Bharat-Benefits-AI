# NextAuth.js secret used to sign session JWTs.
# Should match the backend's JWT_SECRET so backend Fastify and frontend
# NextAuth.js produce mutually verifiable tokens.
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="change-me-in-production-use-a-32-byte-random-string"

# Public URL the app runs at; required by NextAuth in production.
NEXTAUTH_URL="http://localhost:3000"

# Backend API base URL — credentials provider posts to <BACKEND_URL>/auth/login.
BACKEND_URL="http://localhost:4000"

# Google OAuth credentials (optional). When unset, the Google provider is
# omitted gracefully so dev environments work without OAuth setup.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
